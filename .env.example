DATABASE_URL=sqlite:///./inboxanchor.db
INBOXANCHOR_DATA_DIR=
INBOXANCHOR_ENV=development
INBOXANCHOR_DEFAULT_PROVIDER=fake
INBOXANCHOR_DRY_RUN=true
INBOXANCHOR_LLM_PROVIDER=mock
INBOXANCHOR_OPENAI_MODEL=gpt-4o-mini
INBOXANCHOR_GROQ_MODEL=llama-3.1-8b-instant
INBOXANCHOR_LLM_TIMEOUT_SECONDS=30
INBOXANCHOR_LLM_RETRY_ATTEMPTS=3
INBOXANCHOR_LLM_RETRY_BASE_DELAY_SECONDS=1.0
INBOXANCHOR_LLM_RETRY_MAX_DELAY_SECONDS=30.0
INBOXANCHOR_USE_SMART_CLASSIFIER=false
INBOXANCHOR_SESSION_TTL_DAYS=30

OPENAI_API_KEY=
GROQ_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

GMAIL_CREDENTIALS_PATH=
GMAIL_TOKEN_PATH=
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/oauth/gmail/callback
GMAIL_PUBSUB_TOPIC=
GMAIL_WATCH_LABEL_IDS=INBOX
INBOXANCHOR_GMAIL_WATCH_AUTO_RENEW=true
INBOXANCHOR_SENDER_WARMUP_MONTHS_BACK=6
INBOXANCHOR_SENDER_WARMUP_MAX_EMAILS=50000
INBOXANCHOR_SENDER_WARMUP_BATCH_SIZE=500
INBOXANCHOR_SENDER_WARMUP_AUTO_ON_FIRST_RUN=true
INBOXANCHOR_ALIAS_MANAGED_ENABLED=false
INBOXANCHOR_ALIAS_DOMAIN=
INBOXANCHOR_ALIAS_ALLOW_PLUS_FALLBACK=false
INBOXANCHOR_ALIAS_RESOLVER_SECRET=changeme-use-a-long-random-string
INBOXANCHOR_ALIAS_RESOLVER_BASE_URL=
INBOXANCHOR_ALIAS_INBOUND_READY=false

IMAP_HOST=
IMAP_PORT=993
IMAP_USERNAME=
IMAP_PASSWORD=
IMAP_USE_SSL=true
IMAP_MAILBOX=INBOX
IMAP_ARCHIVE_MAILBOX=
IMAP_TRASH_MAILBOX=
